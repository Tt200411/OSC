 import torch
 from torch import nn
+import torch.nn.functional as F
 import math
 
+
+class PerturbedActivation(nn.Module):
+    def __init__(self, base, amplitude=0.0, frequency=1.0, phase=0.0, waveform="sin"):
+        super().__init__()
+        self.base = base.lower()
+        self.amplitude = float(amplitude)
+        self.frequency = float(frequency)
+        self.phase = float(phase)
+        self.waveform = waveform
+
+    def _base(self, x):
+        if self.base == "gelu":
+            return F.gelu(x)
+        if self.base == "relu":
+            return F.relu(x)
+        if self.base in {"swish", "silu"}:
+            return F.silu(x)
+        if self.base == "tanh":
+            return torch.tanh(x)
+        if self.base == "softsign":
+            return F.softsign(x)
+        raise RuntimeError(f"Unsupported activation base: {self.base}")
+
+    def forward(self, x):
+        y = self._base(x)
+        argument = self.frequency * x + self.phase
+        if self.waveform == "sin":
+            return y + self.amplitude * torch.sin(argument)
+        if self.waveform == "cos":
+            return y + self.amplitude * torch.cos(argument)
+        raise RuntimeError(f"Unsupported perturbation waveform: {self.waveform}")
+
