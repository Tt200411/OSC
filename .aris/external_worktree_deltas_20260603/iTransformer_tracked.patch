+def get_activation_fn(activation):
+    activation = str(activation).lower()
+    if activation == "relu":
+        return F.relu
+    if activation == "gelu":
+        return F.gelu
+    if activation == "tanh":
+        return torch.tanh
+    if activation == "softsign":
+        return F.softsign
+    if activation in {"silu", "swish"}:
+        return F.silu
+    if activation in {"tanh_sin001", "tanh_sin_001"}:
+        return lambda x: torch.tanh(x) + 0.01 * torch.sin(x)
+    if activation == "tanh_sin":
+        return lambda x: torch.tanh(x) + 0.01 * torch.sin(x)
+    raise ValueError(f"Unsupported activation: {activation}")
 
 
